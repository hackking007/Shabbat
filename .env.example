# Copy this file to .env and fill in any values you want.
# All variables are OPTIONAL - the app will run with sensible defaults.

# Google Gemini API key (optional). If empty, the app uses built-in Hebrew fallback content.
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Server port for the Express backend.
PORT=4000

# MongoDB connection string.
# Default points to a local MongoDB instance on the same machine.
# Login & checklist features require a running MongoDB; Shabbat times + content work without it.
MONGO_URI=mongodb://localhost:27017/shabbat-app

# Secret used to sign JWT auth tokens. Change to a long random string in production.
JWT_SECRET=change_this_to_a_random_string_for_production
